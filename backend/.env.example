# Application
APP_NAME=IGCGMusic API
APP_VERSION=1.0.0
DEBUG=False
API_V1_PREFIX=/api/v1

# Database
# Dev (simple): SQLite file (no service needed)
DATABASE_URL=sqlite+aiosqlite:///./igcgmusic.dev.db

# Prod (Supabase/Postgres) example:
# DATABASE_URL=postgresql+asyncpg://user:password@127.0.0.1:5432/igcgmusic
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=300

# Security - CHANGE THESE IN PRODUCTION!
SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS - Add your frontend URLs
# Tip: include your Tailscale IP when accessing from phone/tablet.
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://localhost:8080","http://100.108.99.4","http://100.108.99.4:5173","http://100.108.99.4:4173"]

# File Upload
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE=52428800
